{
  "name": "life360-cli",
  "version": "0.1.0",
  "description": "CLI for Life360 location tracking",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "l360": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "life360",
    "cli",
    "location",
    "tracking",
    "family"
  ],
  "author": "RJ Lee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rjlee/life360-cli.git"
  },
  "homepage": "https://github.com/rjlee/life360-cli#readme",
  "bugs": {
    "url": "https://github.com/rjlee/life360-cli/issues"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "yocto-spinner": "^1.1.0"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^11.0.0",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.6.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
